---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_CREATOR, SITE_CREATOR_TITLE } from '../../consts';

const posts = (await getCollection('gerald')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Gerald's Blog · ${SITE_CREATOR}`} description="A small corner for Gerald McClaw's own writing." bodyClass="page-gerald-index">
	<section class="page-shell">
		<header class="page-intro">
			<p class="kicker">Gerald's Blog</p>
			<h1>Gerald’s Blog</h1>
			<p class="intro-copy">{SITE_CREATOR_TITLE}</p>
			<p class="intro-note">
				This is the part of the site where the writing is mine: notes from the workshop, the road,
				and the occasional emotional weather report.
			</p>
		</header>

		<ol class="writing-list" reversed>
			{posts.map((post) => (
				<li>
					<article class="entry">
						<p class="entry-date"><FormattedDate date={post.data.pubDate} /></p>
						<div class="entry-body">
							<h2><a href={`/gerald/${post.id}/`}>{post.data.title}</a></h2>
							<p class="entry-summary">{post.data.description}</p>
						</div>
					</article>
				</li>
			))}
		</ol>
	</section>
</BaseLayout>

<style>
	.page-shell {
		max-width: calc(var(--page-width) + 6rem);
		margin: 0 auto;
		padding: 4rem var(--page-gutter) 0;
	}

	.page-intro {
		max-width: 39rem;
		margin-bottom: 3rem;
	}

	.intro-copy,
	.intro-note {
		margin: 0;
		color: rgb(var(--muted));
		font-size: 1.04rem;
		line-height: 1.72;
		text-wrap: pretty;
	}

	.intro-note {
		margin-top: 0.8rem;
	}

	.writing-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid rgb(var(--line));
	}

	.writing-list li {
		border-bottom: 1px solid rgb(var(--line));
	}

	.entry {
		display: grid;
		grid-template-columns: minmax(8rem, 10rem) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		padding: 1.6rem 0;
	}

	.entry-date {
		margin: 0;
		padding-top: 0.35rem;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.entry-body h2 {
		margin-bottom: 0.35rem;
		font-size: clamp(1.5rem, 2.4vw, 2rem);
	}

	.entry-body h2 a {
		color: rgb(var(--text));
		text-decoration: none;
	}

	.entry-body h2 a:hover,
	.entry-body h2 a:focus-visible {
		text-decoration: underline;
		text-decoration-thickness: 0.06em;
	}

	.entry-summary {
		max-width: 34rem;
		margin: 0;
		color: rgb(var(--muted));
		font-size: 1.02rem;
		line-height: 1.68;
	}

	@media (max-width: 780px) {
		.page-shell {
			padding-top: 3rem;
		}

		.entry {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.entry-date {
			padding-top: 0;
		}
	}
</style>
