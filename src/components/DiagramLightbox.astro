<!--
  Lightweight lightbox for D2 diagrams.
  Click any diagram to view it full-screen with zoom/pan.
  Press Escape or click the backdrop to close.
-->

<div id="diagram-lightbox" class="diagram-lightbox" aria-hidden="true" role="dialog" aria-label="Diagram viewer">
	<button class="lightbox-close" aria-label="Close diagram viewer">&times;</button>
	<div class="lightbox-scroll">
		<img class="lightbox-img" alt="" />
	</div>
</div>

<style is:global>
	/* Make D2 diagram images look clickable */
	.prose img[src*="/d2/"] {
		cursor: zoom-in;
		transition: opacity 0.15s ease;
		border-radius: 0.5rem;
		border: 1px solid rgb(var(--line, 220 220 220));
	}

	.prose img[src*="/d2/"]:hover {
		opacity: 0.85;
	}
</style>

<style>
	.diagram-lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.88);
		backdrop-filter: blur(4px);
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.2s ease, visibility 0.2s ease;
	}

	.diagram-lightbox[aria-hidden="false"] {
		opacity: 1;
		visibility: visible;
	}

	.lightbox-close {
		position: fixed;
		top: 1rem;
		right: 1.25rem;
		z-index: 10000;
		background: none;
		border: none;
		color: #fff;
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
		padding: 0.25rem 0.5rem;
		opacity: 0.7;
		transition: opacity 0.15s ease;
	}

	.lightbox-close:hover {
		opacity: 1;
	}

	.lightbox-scroll {
		overflow: auto;
		max-width: 95vw;
		max-height: 95vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox-img {
		max-width: none;
		max-height: none;
		width: auto;
		height: auto;
		/* SVGs render at native size so they're sharp when zoomed */
	}

	/* When diagram fits in viewport, constrain it */
	.lightbox-scroll.fit .lightbox-img {
		max-width: 95vw;
		max-height: 95vh;
		object-fit: contain;
	}
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const lightbox = document.getElementById('diagram-lightbox');
		if (!lightbox) return;

		const img = lightbox.querySelector('.lightbox-img') as HTMLImageElement;
		const scrollContainer = lightbox.querySelector('.lightbox-scroll') as HTMLDivElement;
		let isZoomed = false;

		function open(src: string) {
			img.src = src;
			isZoomed = false;
			scrollContainer.classList.add('fit');
			lightbox.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		}

		function close() {
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			img.src = '';
		}

		// Toggle between fit-to-screen and native size
		img.addEventListener('click', (e) => {
			e.stopPropagation();
			isZoomed = !isZoomed;
			if (isZoomed) {
				scrollContainer.classList.remove('fit');
				img.style.cursor = 'zoom-out';
			} else {
				scrollContainer.classList.add('fit');
				img.style.cursor = 'zoom-in';
			}
		});

		// Click any D2 diagram to open
		document.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.tagName === 'IMG' && target.getAttribute('src')?.includes('/d2/')) {
				open((target as HTMLImageElement).src);
			}
		});

		// Close on backdrop click
		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox || e.target === scrollContainer) {
				close();
			}
		});

		// Close button
		lightbox.querySelector('.lightbox-close')?.addEventListener('click', close);

		// Escape key
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && lightbox.getAttribute('aria-hidden') === 'false') {
				close();
			}
		});
	});
</script>
