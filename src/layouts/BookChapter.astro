---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { SITE_AUTHOR } from '../consts';

interface Props {
	title: string;
	description: string;
	prev?: { id: string; title: string } | null;
	next?: { id: string; title: string } | null;
}

const { title, description, prev, next } = Astro.props;
---

<BaseLayout
	title={`${title} · SFOSC Book · ${SITE_AUTHOR}`}
	description={description}
	bodyClass="page-post"
	ogType="article"
	author={SITE_AUTHOR}
>
	<article class="post-shell">
		<header class="post-meta">
			<p class="kicker"><a href="/sfosc/">SFOSC Book</a></p>
			<h1>{title}</h1>
			<p class="dek">{description}</p>
		</header>
		<div class="prose">
			<slot />
		</div>
		<nav class="chapter-nav" aria-label="Chapter navigation">
			<div class="nav-prev">
				{prev && (
					<a href={`/sfosc/${prev.id}/`}>
						<span class="nav-label">← Previous</span>
						<span class="nav-title">{prev.title}</span>
					</a>
				)}
			</div>
			<div class="nav-next">
				{next && (
					<a href={`/sfosc/${next.id}/`}>
						<span class="nav-label">Next →</span>
						<span class="nav-title">{next.title}</span>
					</a>
				)}
			</div>
		</nav>
	</article>
</BaseLayout>

<style>
	.post-shell {
		max-width: calc(var(--article-width) + 8rem);
		margin: 0 auto;
		padding: 4.5rem var(--page-gutter) 0;
	}

	.post-meta {
		max-width: var(--article-width);
		margin: 0 auto 2.75rem;
	}

	.post-meta .kicker {
		margin-bottom: 1rem;
	}

	.post-meta .kicker a {
		color: inherit;
		text-decoration: none;
	}

	.dek {
		max-width: 34rem;
		margin-bottom: 1.15rem;
		color: rgb(var(--muted));
		font-size: 1.13rem;
		line-height: 1.68;
		text-wrap: pretty;
	}

	.prose {
		max-width: var(--article-width);
		margin: 0 auto;
	}

	.prose :global(> p:first-child) {
		font-size: 1.22em;
		line-height: 1.72;
		color: rgb(var(--text));
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(h3) {
		margin-top: 2.2rem;
	}

	.prose :global(a) {
		text-decoration-thickness: 0.06em;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.35em;
	}

	.prose :global(blockquote) {
		margin-left: 0;
		margin-right: 0;
	}

	.chapter-nav {
		max-width: var(--article-width);
		margin: 4rem auto 2rem;
		padding-top: 2rem;
		border-top: 1px solid rgb(var(--line));
		display: flex;
		justify-content: space-between;
		gap: 2rem;
	}

	.nav-prev, .nav-next {
		flex: 1;
		min-width: 0;
	}

	.nav-next {
		text-align: right;
	}

	.chapter-nav a {
		display: block;
		color: rgb(var(--text));
		text-decoration: none;
	}

	.chapter-nav a:hover .nav-title {
		text-decoration: underline;
		text-decoration-thickness: 0.06em;
	}

	.nav-label {
		display: block;
		margin-bottom: 0.25rem;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.nav-title {
		font-size: 1.05rem;
		line-height: 1.4;
	}

	@media (max-width: 720px) {
		.post-shell {
			padding-top: 3rem;
		}

		.dek {
			font-size: 1.05rem;
		}

		.prose :global(> p:first-child) {
			font-size: 1.1em;
		}

		.chapter-nav {
			flex-direction: column;
			gap: 1.5rem;
		}

		.nav-next {
			text-align: left;
		}
	}
</style>
