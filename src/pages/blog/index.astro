---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Writing · ${SITE_AUTHOR}`} description={SITE_DESCRIPTION} bodyClass="page-writing">
	<section class="page-shell">
		<header class="page-intro">
			<p class="kicker">Archive</p>
			<h1>All writing</h1>
			<p>Every post, newest first.</p>
		</header>

		<ol class="writing-list" reversed>
			{posts.map((post) => (
				<li>
					<article class="entry">
						<p class="entry-date"><FormattedDate date={post.data.pubDate} /></p>
						<div class="entry-body">
							<h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
							<p class="entry-summary">{post.data.description}</p>
						</div>
					</article>
				</li>
			))}
		</ol>
	</section>
</BaseLayout>

<style>
	.page-shell {
		max-width: calc(var(--page-width) + 6rem);
		margin: 0 auto;
		padding: 4rem var(--page-gutter) 0;
	}

	.page-intro {
		max-width: 34rem;
		margin-bottom: 2.5rem;
	}

	.page-intro p:last-child {
		margin: 0;
		color: rgb(var(--muted));
	}

	.writing-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid rgb(var(--line));
	}

	.writing-list li {
		border-bottom: 1px solid rgb(var(--line));
	}

	.entry {
		display: grid;
		grid-template-columns: minmax(8rem, 10rem) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		padding: 1.6rem 0;
	}

	.entry-date {
		margin: 0;
		padding-top: 0.35rem;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.entry-body h2 {
		margin-bottom: 0.35rem;
	}

	.entry-body h2 a {
		color: rgb(var(--text));
		text-decoration: none;
	}

	.entry-body h2 a:hover,
	.entry-body h2 a:focus-visible {
		text-decoration: underline;
	}

	.entry-summary {
		margin: 0;
		max-width: 34rem;
		color: rgb(var(--muted));
	}

	@media (max-width: 780px) {
		.page-shell {
			padding-top: 3rem;
		}

		.entry {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.entry-date {
			padding-top: 0;
		}
	}
</style>
