---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, draft = false } = Astro.props;
---

<BaseLayout title={`${title} · ${SITE_AUTHOR}`} description={description} bodyClass="page-post">
	<article class="post-shell">
		<header class="post-meta">
			<p class="kicker"><a href="/">Writing</a></p>
			<h1>
				{title}
				{draft && <span class="draft-badge">Draft</span>}
			</h1>
			<p class="dek">{description}</p>
			<p class="date-row">
				Published <FormattedDate date={pubDate} />
				{updatedDate && <> · Updated <FormattedDate date={updatedDate} /></>}
			</p>
		</header>
		{heroImage && (
			<div class="hero-image">
				<Image width={1400} height={700} src={heroImage} alt="" />
			</div>
		)}
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.post-shell {
		max-width: calc(var(--article-width) + 8rem);
		margin: 0 auto;
		padding: 4.5rem var(--page-gutter) 0;
	}

	.post-meta {
		max-width: var(--article-width);
		margin: 0 auto 2.75rem;
	}

	.post-meta .kicker {
		margin-bottom: 1rem;
	}

	.post-meta .kicker a {
		color: inherit;
		text-decoration: none;
	}

	.post-meta h1 {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	.draft-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.55rem;
		border: 1px solid rgb(var(--line));
		border-radius: 999px;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		vertical-align: middle;
	}

	.dek {
		max-width: 34rem;
		margin-bottom: 1.15rem;
		color: rgb(var(--muted));
		font-size: 1.13rem;
		line-height: 1.68;
		text-wrap: pretty;
	}

	.date-row {
		margin: 0;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.92rem;
	}

	.hero-image {
		margin: 0 auto 2.5rem;
		max-width: calc(var(--article-width) + 4rem);
	}

	.hero-image img {
		width: 100%;
		display: block;
		border: 1px solid rgb(var(--line));
		border-radius: 1rem;
		box-shadow: var(--shadow);
	}

	.prose {
		max-width: var(--article-width);
		margin: 0 auto;
	}

	.prose :global(> p:first-child) {
		font-size: 1.22em;
		line-height: 1.72;
		color: rgb(var(--text));
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(h3) {
		margin-top: 2.2rem;
	}

	.prose :global(a) {
		text-decoration-thickness: 0.06em;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.35em;
	}

	.prose :global(blockquote) {
		margin-left: 0;
		margin-right: 0;
	}

	@media (max-width: 720px) {
		.post-shell {
			padding-top: 3rem;
		}

		.dek {
			font-size: 1.05rem;
		}

		.prose :global(> p:first-child) {
			font-size: 1.1em;
		}
	}
</style>
