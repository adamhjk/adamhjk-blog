---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={`${title} · ${SITE_AUTHOR}`} description={description} bodyClass="page-post">
	<article class="post-shell">
		<header class="post-meta">
			<p class="eyebrow"><a href="/">Writing</a></p>
			<h1>{title}</h1>
			<p class="dek">{description}</p>
			<p class="date-row">
				<FormattedDate date={pubDate} />
				{updatedDate && <> · Updated <FormattedDate date={updatedDate} /></>}
			</p>
		</header>
		{heroImage && (
			<div class="hero-image">
				<Image width={1400} height={700} src={heroImage} alt="" />
			</div>
		)}
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.post-shell {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 3rem var(--page-gutter) 0;
	}

	.post-meta {
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		margin-bottom: 0.75rem;
		font-size: 0.95rem;
		color: rgb(var(--muted));
	}

	.eyebrow a {
		color: inherit;
	}

	.dek {
		font-size: 1.1rem;
		color: rgb(var(--muted));
		max-width: 34rem;
	}

	.date-row {
		color: rgb(var(--muted));
		font-size: 0.95rem;
		margin: 0;
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		width: 100%;
		display: block;
		border: 1px solid rgb(var(--line));
	}

	.prose {
		font-size: 1rem;
	}

	.prose :global(h2),
	.prose :global(h3) {
		margin-top: 2.25rem;
	}

	.prose :global(p),
	.prose :global(ul),
	.prose :global(ol),
	.prose :global(pre),
	.prose :global(blockquote) {
		margin-bottom: 1.25rem;
	}
</style>
