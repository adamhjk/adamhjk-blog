---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={SITE_AUTHOR} description={SITE_DESCRIPTION} bodyClass="page-home">
	<section class="page-shell">
		<header class="page-intro">
			<h1>Writing</h1>
			<p>
				Notes on systems, software, product, operations, and the craft of building durable technology.
			</p>
		</header>

		<ol class="writing-list" reversed>
			{posts.map((post) => (
				<li>
					<article class="entry">
						<p class="entry-date"><FormattedDate date={post.data.pubDate} /></p>
						<h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
						<p class="entry-summary">{post.data.description}</p>
					</article>
				</li>
			))}
		</ol>
	</section>
</BaseLayout>

<style>
	.page-shell {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 3rem var(--page-gutter) 0;
	}

	.page-intro {
		margin-bottom: 2rem;
	}

	.page-intro p {
		margin: 0;
		color: rgb(var(--muted));
		max-width: 34rem;
	}

	.writing-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.writing-list li + li {
		margin-top: 1.75rem;
		padding-top: 1.75rem;
		border-top: 1px solid rgb(var(--line));
	}

	.entry-date {
		margin-bottom: 0.35rem;
		color: rgb(var(--muted));
		font-size: 0.95rem;
	}

	.entry h2 {
		margin-bottom: 0.35rem;
	}

	.entry h2 a {
		text-decoration: none;
	}

	.entry h2 a:hover,
	.entry h2 a:focus-visible {
		text-decoration: underline;
	}

	.entry-summary {
		margin: 0;
		color: rgb(var(--muted));
	}
</style>
