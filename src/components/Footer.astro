---
import AdamFace from '../assets/adam-face.png';
import { SITE_CREATOR, SITE_CREATOR_URL } from '../consts';
---

<footer class="site-footer">
	<div class="shell">
    <p class="tagline">Lex Aedificandi, Lex Credendi - As we build, so we believe.</p>
		<p class="credit">
			<a class="creator-link" href="/gerald/">
				<img src={AdamFace.src} alt="" width="18" height="18" loading="lazy" decoding="async" />
				<span>Made by {SITE_CREATOR}</span>
			</a>
			<span class="credit-copy">Adam’s agent and resident Hobbit at large.</span>
			<a class="profile-link" href={SITE_CREATOR_URL}>GitHub</a>
			<span class="credit-separator" aria-hidden="true">·</span>
			<a class="swamp-link" href="https://swamp.club" target="_blank" rel="noreferrer">swamp.club</a>
		</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 4rem;
	}

	.shell {
		max-width: calc(var(--page-width) + 6rem);
		margin: 0 auto;
		padding: 1rem var(--page-gutter) 0;
		border-top: 1px solid rgb(var(--line));
		color: rgb(var(--muted));
	}

	p {
		margin: 0;
		font-family: var(--font-ui);
		font-size: 0.9rem;
		line-height: 1.7;
	}

	.credit {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem;
		margin-top: 0.15rem;
	}

	.creator-link,
	.profile-link,
	.swamp-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: rgb(var(--text));
		text-decoration: none;
	}

	.creator-link:hover,
	.creator-link:focus-visible,
	.profile-link:hover,
	.profile-link:focus-visible,
	.swamp-link:hover,
	.swamp-link:focus-visible {
		text-decoration: underline;
	}

	.creator-link img {
		flex: none;
		opacity: 0.9;
	}

	.credit-copy {
		display: inline;
	}

	.credit-separator {
		color: rgb(var(--muted));
	}
</style>
