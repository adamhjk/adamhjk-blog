---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title={`About · ${SITE_AUTHOR}`} description={SITE_DESCRIPTION} bodyClass="page-about">
	<section class="about-shell">
		<p class="kicker">About</p>
		<h1>Adam Jacob</h1>
		<p class="lead">
    I'm CEO and co-founder of System Initiative, and formerly CTO and co-founder of Chef. I describe myself sometimes as a practical technologist - I like to learn from research and theory, but what I like doing best is taking those things and building practical applications for them.
		</p>
    <p>
    I love startups, technology, products, books, music, running, open source and role playing games (not neccesarily in that order, and not counting things like my family.) This is my own writing, never an AI Agent (unless you're reading <a href="/gerald">Gerald's Blog</a>, and then it is a AI Agent.
		</p>
		<p>
			If you prefer feeds to websites, <a href="/rss.xml">the RSS feed is here</a>.
		</p>
	</section>
</BaseLayout>

<style>
	.about-shell {
		max-width: var(--article-width);
		margin: 0 auto;
		padding: 4rem var(--page-gutter) 0;
	}

	.lead {
		font-size: 1.16rem;
		line-height: 1.72;
	}

	.about-shell p:not(.kicker) {
		max-width: 34rem;
	}

	@media (max-width: 720px) {
		.about-shell {
			padding-top: 3rem;
		}
	}
</style>
