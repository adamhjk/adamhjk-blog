<!--
  Lightweight lightbox for D2 diagrams.
  Click any diagram to view it full-screen.
  Click again to toggle between fit and full-size.
  Press Escape or click the backdrop to close.
-->

<div id="diagram-lightbox" class="diagram-lightbox" aria-hidden="true" role="dialog" aria-label="Diagram viewer">
	<button class="lightbox-close" aria-label="Close diagram viewer">&times;</button>
	<div class="lightbox-body">
		<img class="lightbox-img" src="" alt="Diagram (zoomed)" />
	</div>
</div>

<style is:global>
	/* Make D2 diagram images look clickable */
	.prose img[src*="/d2/"] {
		cursor: zoom-in;
		transition: opacity 0.15s ease;
		border-radius: 0.5rem;
		border: 1px solid rgb(var(--line, 220 220 220));
	}

	.prose img[src*="/d2/"]:hover {
		opacity: 0.85;
	}

	/* Lightbox overlay */
	.diagram-lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: rgba(0, 0, 0, 0.88);
		backdrop-filter: blur(4px);
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.2s ease, visibility 0.2s ease;
		overflow: auto;
	}

	.diagram-lightbox[aria-hidden="false"] {
		opacity: 1;
		visibility: visible;
	}

	.diagram-lightbox .lightbox-close {
		position: fixed;
		top: 1rem;
		right: 1.25rem;
		z-index: 10001;
		background: rgba(0, 0, 0, 0.5);
		border: none;
		border-radius: 50%;
		color: #fff;
		font-size: 1.5rem;
		width: 2.5rem;
		height: 2.5rem;
		line-height: 1;
		cursor: pointer;
		opacity: 0.8;
		transition: opacity 0.15s ease;
	}

	.diagram-lightbox .lightbox-close:hover {
		opacity: 1;
	}

	.diagram-lightbox .lightbox-body {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}

	.diagram-lightbox .lightbox-img {
		background: #fff;
		border-radius: 0.5rem;
		box-shadow: 0 4px 40px rgba(0, 0, 0, 0.4);
		cursor: zoom-in;
		max-width: 90vw;
		max-height: 90vh;
	}

	.diagram-lightbox.zoomed .lightbox-body {
		align-items: flex-start;
	}

	.diagram-lightbox.zoomed .lightbox-img {
		max-width: none;
		max-height: none;
		cursor: zoom-out;
	}
</style>

<script>
	const lightbox = document.getElementById('diagram-lightbox')!;
	const img = lightbox.querySelector('.lightbox-img') as HTMLImageElement;
	const body = lightbox.querySelector('.lightbox-body') as HTMLDivElement;

	function open(src: string) {
		img.src = src;
		lightbox.classList.remove('zoomed');
		lightbox.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';
	}

	function close() {
		lightbox.setAttribute('aria-hidden', 'true');
		lightbox.classList.remove('zoomed');
		document.body.style.overflow = '';
		setTimeout(() => { img.src = ''; }, 200);
	}

	// Click any D2 diagram on the page to open
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (target.tagName === 'IMG' && target.getAttribute('src')?.includes('/d2/')) {
			e.preventDefault();
			open((target as HTMLImageElement).src);
		}
	});

	// Click image to toggle zoom
	img.addEventListener('click', (e) => {
		e.stopPropagation();
		lightbox.classList.toggle('zoomed');
	});

	// Click backdrop to close
	body.addEventListener('click', (e) => {
		if (e.target === body) close();
	});
	lightbox.addEventListener('click', (e) => {
		if (e.target === lightbox) close();
	});

	// Close button
	lightbox.querySelector('.lightbox-close')!.addEventListener('click', close);

	// Escape key
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && lightbox.getAttribute('aria-hidden') === 'false') {
			close();
		}
	});
</script>
