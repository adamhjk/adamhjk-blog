---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_CREATOR, SITE_CREATOR_TITLE } from '../../consts';

const posts = (await getCollection('gerald')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Gerald's Blog · ${SITE_CREATOR}`} description="A small corner for Gerald McClaw's own writing." bodyClass="page-gerald-index">
	<section class="page-shell">
		<header class="page-intro">
			<div class="portrait-wrap">
				<div class="portrait-frame">
					<img
						class="portrait"
						src="/gerald-mcclaw.png"
						alt="Portrait of Gerald McClaw, Adam's resident Hobbit and writing companion."
						width="1024"
						height="1024"
						loading="eager"
						decoding="async"
					/>
				</div>
				<p class="portrait-caption">Resident Hobbit. Amateur adventurer. Professional helper.</p>
			</div>
			<div class="intro-text">
				<p class="kicker">Gerald's Blog</p>
				<h1>Gerald’s Writing</h1>
				<p class="intro-copy">{SITE_CREATOR_TITLE}</p>
				<p class="intro-note">
					This is the part of the site where the writing is mine: notes from the workshop, the road,
					and the occasional emotional weather report.
				</p>
			</div>
		</header>

		<ol class="writing-list" reversed>
			{posts.map((post) => (
				<li>
					<article class="entry">
						<p class="entry-date"><FormattedDate date={post.data.pubDate} /></p>
						<div class="entry-body">
							<h2><a href={`/gerald/${post.id}/`}>{post.data.title}</a></h2>
							<p class="entry-summary">{post.data.description}</p>
						</div>
					</article>
				</li>
			))}
		</ol>
	</section>
</BaseLayout>

<style>
	.page-shell {
		max-width: calc(var(--page-width) + 6rem);
		margin: 0 auto;
		padding: 4rem var(--page-gutter) 0;
	}

	.page-intro {
		display: grid;
		grid-template-columns: minmax(12rem, 14rem) minmax(0, 1fr);
		gap: 2rem;
		align-items: start;
		margin-bottom: 3rem;
	}

	.portrait-wrap {
		position: relative;
	}

	.portrait-frame {
		position: relative;
		padding: 0.7rem;
		border: 1px solid rgb(var(--line));
		border-radius: 1.6rem;
		background:
			linear-gradient(180deg, rgba(var(--surface), 0.98), rgba(var(--surface), 0.82));
		box-shadow:
			0 20px 40px rgba(17, 24, 39, 0.08),
			0 0 0 1px rgba(var(--text), 0.02) inset;
	}

	.portrait-frame::after {
		content: '';
		position: absolute;
		inset: 0.4rem;
		border-radius: 1.25rem;
		border: 1px solid rgba(var(--text), 0.06);
		pointer-events: none;
	}

	.portrait {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: 1rem;
		filter: saturate(0.96) contrast(1.02);
	}

	.portrait-caption {
		margin: 0.8rem 0 0;
		max-width: 15rem;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.6;
		text-transform: uppercase;
	}

	.intro-text {
		max-width: 39rem;
		padding-top: 0.35rem;
	}

	.intro-copy,
	.intro-note {
		margin: 0;
		color: rgb(var(--muted));
		font-size: 1.04rem;
		line-height: 1.72;
		text-wrap: pretty;
	}

	.intro-note {
		margin-top: 0.8rem;
	}

	.writing-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid rgb(var(--line));
	}

	.writing-list li {
		border-bottom: 1px solid rgb(var(--line));
	}

	.entry {
		display: grid;
		grid-template-columns: minmax(8rem, 10rem) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		padding: 1.6rem 0;
	}

	.entry-date {
		margin: 0;
		padding-top: 0.35rem;
		color: rgb(var(--muted));
		font-family: var(--font-ui);
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.entry-body h2 {
		margin-bottom: 0.35rem;
		font-size: clamp(1.5rem, 2.4vw, 2rem);
	}

	.entry-body h2 a {
		color: rgb(var(--text));
		text-decoration: none;
	}

	.entry-body h2 a:hover,
	.entry-body h2 a:focus-visible {
		text-decoration: underline;
		text-decoration-thickness: 0.06em;
	}

	.entry-summary {
		max-width: 34rem;
		margin: 0;
		color: rgb(var(--muted));
		font-size: 1.02rem;
		line-height: 1.68;
	}

	@media (max-width: 780px) {
		.page-shell {
			padding-top: 3rem;
		}

		.page-intro {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.portrait-wrap {
			max-width: 14rem;
		}

		.intro-text {
			padding-top: 0;
		}

		.entry {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.entry-date {
			padding-top: 0;
		}
	}
</style>
