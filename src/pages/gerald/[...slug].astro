---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import GeraldPost from '../../layouts/GeraldPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('gerald');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'gerald'>;

const post = Astro.props;
const { Content } = await render(post);
---

<GeraldPost {...post.data}>
	<Content />
</GeraldPost>
