---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title={`About · ${SITE_AUTHOR}`} description={SITE_DESCRIPTION} bodyClass="page-about">
	<section class="about-shell">
		<h1>About</h1>
		<p>
			Adam Jacob is CEO and co-founder of System Initiative, and formerly CTO and co-founder of Chef.
		</p>
		<p>
			This site is a plain place for writing about systems, infrastructure, software, product, and the work
			of making technology hold up over time.
		</p>
		<p>
			If you prefer feeds to websites, <a href="/rss.xml">the RSS feed is here</a>.
		</p>
	</section>
</BaseLayout>

<style>
	.about-shell {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 3rem var(--page-gutter) 0;
	}

	.about-shell p {
		max-width: 34rem;
	}
</style>
