---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
	<div class="shell">
		<div class="brand-row">
			<p class="brand"><a href="/">{SITE_TITLE}</a></p>
		</div>
		<div class="controls">
			<nav aria-label="Primary" class="nav">
				<HeaderLink href="/">Writing</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<a href="/rss.xml">RSS</a>
			</nav>
			<ThemeToggle />
		</div>
	</div>
</header>

<style>
	.site-header {
		padding: 1.25rem 0 0;
	}

	.shell {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 0 var(--page-gutter);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.brand {
		margin: 0;
		font-size: 1rem;
	}

	.brand a,
	.brand a:visited {
		text-decoration: none;
		color: rgb(var(--text));
	}

	.controls,
	.nav {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.nav a {
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.nav a:hover,
	.nav a:focus-visible,
	.nav a.active {
		color: rgb(var(--text));
	}

	@media (max-width: 640px) {
		.shell {
			align-items: flex-start;
			flex-direction: column;
		}

		.controls {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
