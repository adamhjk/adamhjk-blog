---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="shell">
		<p class="brand"><a href="/">{SITE_TITLE}</a></p>
		<nav aria-label="Primary" class="nav">
			<HeaderLink href="/">Adam’s Writing</HeaderLink>
			<HeaderLink href="/gerald/">Gerald’s Writing</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="/rss.xml" aria-label="RSS feed">RSS</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		padding: 1.4rem 0 0;
	}

	.shell {
		max-width: calc(var(--page-width) + 6rem);
		margin: 0 auto;
		padding: 0 var(--page-gutter) 1rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		border-bottom: 1px solid rgb(var(--line));
	}

	.brand {
		margin: 0;
		font-size: 1.05rem;
	}

	.brand a,
	.brand a:visited {
		color: rgb(var(--text));
		text-decoration: none;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-family: var(--font-ui);
		font-size: 0.86rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.nav :global(a) {
		display: inline-flex;
		align-items: center;
		min-height: 2.75rem;
		padding: 0 0.55rem;
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.nav :global(a:hover),
	.nav :global(a:focus-visible),
	.nav :global(a.active) {
		color: rgb(var(--text));
	}

	@media (max-width: 640px) {
		.shell {
			align-items: flex-start;
			flex-direction: column;
			padding-bottom: 0.8rem;
		}

		.nav {
			margin-left: -0.55rem;
			flex-wrap: wrap;
		}
	}
</style>
